{
  "name": "mcp-toolmetry",
  "version": "0.2.0",
  "description": "Measure how well AI agents actually use your MCP server's tools — then rewrite the tool descriptions and prove the improvement with before/after data.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "toolmetry": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujugithub/toolmetry.git"
  },
  "homepage": "https://github.com/sujugithub/toolmetry#readme",
  "bugs": {
    "url": "https://github.com/sujugithub/toolmetry/issues"
  },
  "author": "Sujay",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents",
    "tool-use",
    "evals",
    "tool-descriptions",
    "llm"
  ]
}
